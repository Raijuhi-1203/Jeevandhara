<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".Activities.PageProductDetails"
        android:orientation="vertical">

        <include layout="@layout/header"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <androidx.core.widget.NestedScrollView
                        android:layout_marginBottom="70dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_above="@+id/bt_addcart">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_margin="0dp"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/img"
                                android:src="@drawable/cooler"
                                android:layout_width="match_parent"
                                android:layout_height="350dp"
                                android:padding="5dp" />

                            <TextView
                                android:id="@+id/txnm"
                                android:layout_marginLeft="5dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="5dp"
                                android:textStyle="bold"
                                android:textSize="16dp"
                                android:text="AISEN 50 L Window Air Cooler (White, VERA)"
                                android:fontFamily="@font/custom_font"
                                android:textAlignment="textStart"
                                android:textColor="@color/black" />

                            <TextView
                                android:fontFamily="@font/custom_font"
                                android:id="@+id/offmrp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="5dp"
                                android:padding="5dp"
                                android:textSize="16dp"
                                android:text="Rs. 6510"
                                android:textStyle="bold"
                                android:textAlignment="center"
                                android:textColor="@color/blue" />


                            <TextView
                                android:fontFamily="@font/custom_font"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="10dp"
                                android:gravity="start"
                                android:text="About this Item"
                                android:textAlignment="textStart"
                                android:textColor="@color/black"
                                android:textSize="16dp"
                                android:textStyle="bold" />

                            <TextView
                                android:fontFamily="@font/custom_font"
                                android:id="@+id/fulldesp"
                                android:textFontWeight="300"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="5dp"
                                android:gravity="start"
                                android:text="Tank Capacity: 50 L\n
50 ft Air Throw\n
Important Notes\n
1.Allow cross-ventilation in your room for an effective cooling experience.\n
2.The product is ready to use and it does not require any installation."
                                android:textAlignment="textStart"
                                android:textColor="@color/black"
                                android:textSize="14dp"
                                android:textStyle="bold" />

                        </LinearLayout>
                    </androidx.core.widget.NestedScrollView>


                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <TextView
                            android:id="@+id/bt_buy"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:background="@color/blue"
                            android:fontFamily="@font/custom_font"
                            android:layout_alignParentBottom="true"
                            android:layout_gravity="center"
                            android:layout_weight="1"
                            android:textSize="16dp"
                            android:gravity="center"
                            android:padding="6dp"
                            android:text="Buy Now"
                            android:textAlignment="center"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </LinearLayout>

            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>