<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".Activities.Page_CheckOut"
        android:orientation="vertical">

        <include layout="@layout/header"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">


                    <androidx.core.widget.NestedScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_above="@+id/bt_addcart">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:cardElevation="10dp"
                                app:cardCornerRadius="10dp"
                                android:layout_margin="10dp"
                                app:cardBackgroundColor="@color/white"
                                app:cardMaxElevation="12dp"
                                app:cardPreventCornerOverlap="true">

                                <LinearLayout
                                    android:orientation="vertical"
                                    android:padding="3dp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">

                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:fontFamily="@font/custom_font"
                                            android:textAlignment="center"
                                            android:text="Price (₹)"
                                            android:textSize="14dp"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txmrp"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textAlignment="center"
                                            android:text="Shipping (₹)"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txsmrp"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>
                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textAlignment="center"
                                            android:text="Discount (₹)"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txdis"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>
                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:textSize="14dp"
                                            android:textAlignment="center"
                                            android:text="Coupon Dis. (₹)"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txcdis"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>
                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textAlignment="center"
                                            android:text="Amount Paybale (₹)"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txpamt"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginLeft="13dp"
                                android:layout_marginTop="5dp"
                                android:textStyle="bold"
                                android:fontFamily="@font/custom_font"
                                android:text="Payment Method"
                                android:textColor="@color/black"
                                android:textSize="16dp" />

                            <RadioGroup
                                android:id="@+id/radioGroup"
                                android:layout_width="match_parent"
                                android:layout_margin="10dp"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <RadioButton android:id="@+id/radio_cash"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/custom_font"
                                    android:textSize="14dp"
                                    android:text="Cash On Delivery" />

                                <RadioButton android:id="@+id/radio_online"
                                    android:textSize="14dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/custom_font"
                                    android:text="Online" />

                            </RadioGroup>

                            <LinearLayout
                                android:orientation="vertical"
                                android:layout_margin="10dp"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <CheckBox
                                    android:layout_width="match_parent"
                                    android:layout_height="30dp"
                                    android:id="@+id/chk"
                                    android:text="Pay Using Redeem Point"
                                    android:textStyle="bold"
                                    android:layout_gravity="center"
                                    android:fontFamily="@font/custom_font"
                                    android:textColor="@color/blue"/>

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:layout_marginLeft="13dp"
                                    android:layout_marginTop="5dp"
                                    android:id="@+id/point"
                                    android:fontFamily="@font/custom_font"
                                    android:text="    Available balance : 300 point"
                                    android:textColor="@color/black"
                                    android:textSize="16dp" />


                            </LinearLayout>

                        </LinearLayout>
                    </androidx.core.widget.NestedScrollView>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/blue"
                    android:layout_marginBottom="0dp"
                    android:layout_alignParentBottom="true"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/blue"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <TextView
                            android:id="@+id/btorder"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:layout_weight="1"
                            android:fontFamily="@font/custom_font"
                            android:gravity="center"
                            android:padding="6dp"
                            android:text="Place Order"
                            android:textAlignment="center"
                            android:textColor="#fff"
                            android:textSize="19dp" />

                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

