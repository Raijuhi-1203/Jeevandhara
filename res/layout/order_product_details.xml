<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".Activities.Grocery.OrderProductDetails"
        android:orientation="vertical">

        <include layout="@layout/header"/>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <androidx.core.widget.NestedScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_above="@+id/bt_addcart">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:orientation="vertical"
                                android:background="@drawable/cat_box"
                                android:layout_width="match_parent"
                                android:layout_margin="3dp"
                                android:padding="3dp"
                                android:id="@+id/click"
                                android:layout_height="wrap_content">

                                <LinearLayout
                                    android:orientation="horizontal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">

                                    <ImageView
                                        android:padding="5dp"
                                        android:id="@+id/prdimg"
                                        android:layout_gravity="center"
                                        android:src="@drawable/noimg1"
                                        android:layout_width="60dp"
                                        android:layout_height="60dp"/>

                                    <LinearLayout
                                        android:layout_marginRight="10dp"
                                        android:layout_marginLeft="10dp"
                                        android:orientation="vertical"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:id="@+id/txcount"
                                            android:layout_margin="3dp"
                                            android:textColor="@color/black"
                                            android:textSize="16dp"
                                            android:textStyle="bold"
                                            android:fontFamily="@font/custom_font"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>


                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="5dp"
                                android:fontFamily="@font/custom_font"
                                android:padding="5dp"
                                android:text="Order Details"
                                android:textColor="@color/black"
                                android:textSize="16dp"
                                android:textStyle="bold" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:cardElevation="10dp"
                                app:cardCornerRadius="10dp"
                                android:layout_margin="10dp"
                                app:cardBackgroundColor="@color/white"
                                app:cardMaxElevation="12dp"
                                app:cardPreventCornerOverlap="true">

                            <LinearLayout
                                android:padding="5dp"
                                android:background="@drawable/cat_box"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/orderid"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="3dp"
                                    android:fontFamily="@font/custom_font"
                                    android:textColor="@color/black"
                                    android:textSize="14dp" />

                                <TextView
                                    android:visibility="gone"
                                    android:id="@+id/suborderid"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="3dp"
                                    android:fontFamily="@font/custom_font"
                                    android:textColor="@color/black"
                                    android:textSize="14dp" />

                                <TextView
                                    android:id="@+id/txstatus"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_margin="3dp"
                                    android:fontFamily="@font/custom_font"
                                    android:textColor="@color/black"
                                    android:textSize="14dp" />

                            </LinearLayout>

                            </androidx.cardview.widget.CardView>

                            <Button
                                android:textSize="16dp"
                                android:id="@+id/btncancelall"
                                android:visibility="gone"
                                android:layout_margin="5dp"
                                android:fontFamily="@font/custom_font"
                                android:background="@drawable/button"
                                android:textColor="@color/white"
                                android:text="Cancel All items"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="5dp"
                                android:fontFamily="@font/custom_font"
                                android:padding="5dp"
                                android:text="Delivery Address"
                                android:textColor="@color/black"
                                android:textSize="16dp"
                                android:textStyle="bold" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:cardElevation="10dp"
                                app:cardCornerRadius="10dp"
                                android:layout_margin="10dp"
                                app:cardBackgroundColor="@color/white"
                                app:cardMaxElevation="12dp"
                                app:cardPreventCornerOverlap="true">


                            <LinearLayout
                                android:padding="5dp"
                                android:background="@drawable/cat_box"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="10dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txnm"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/custom_font"
                                    android:padding="3dp"
                                    android:text="XXXX"
                                    android:textColor="@color/black"
                                    android:textSize="16dp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txaddress"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/custom_font"
                                    android:padding="3dp"
                                    android:text="XXXX"
                                    android:textColor="@color/black"
                                    android:textSize="14dp" />

                                <TextView
                                    android:id="@+id/txmob"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/custom_font"
                                    android:padding="3dp"
                                    android:text="XXXX"
                                    android:textColor="@color/black"
                                    android:textSize="14dp" />

                                <TextView
                                    android:id="@+id/txmail"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/custom_font"
                                    android:padding="3dp"
                                    android:text="XXXX"
                                    android:textColor="@color/black"
                                    android:textSize="14dp" />

                            </LinearLayout>

                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="5dp"
                                android:fontFamily="@font/custom_font"
                                android:padding="5dp"
                                android:text="Payment Details"
                                android:textColor="@color/black"
                                android:textSize="16dp"
                                android:textStyle="bold" />

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:cardElevation="10dp"
                                app:cardCornerRadius="10dp"
                                android:layout_margin="10dp"
                                app:cardBackgroundColor="@color/white"
                                app:cardMaxElevation="12dp"
                                app:cardPreventCornerOverlap="true">

                                <LinearLayout
                                    android:orientation="vertical"
                                    android:padding="3dp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">

                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:fontFamily="@font/custom_font"
                                            android:textAlignment="center"
                                            android:text="Price (₹)"
                                            android:textSize="14dp"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txmrp"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textAlignment="center"
                                            android:text="Shipping (₹)"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txsmrp"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textAlignment="center"
                                            android:text="Discount (₹)"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txdis"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:textSize="14dp"
                                            android:textAlignment="center"
                                            android:text="Coupon Dis. (₹)"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txcdis"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:padding="2dp"
                                        android:weightSum="2"
                                        android:orientation="horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content">

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textAlignment="center"
                                            android:text="Amount Paybale (₹)"
                                            android:textColor="@color/black"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>

                                        <TextView
                                            android:textSize="14dp"
                                            android:fontFamily="@font/custom_font"
                                            android:textColor="@color/black"
                                            android:textAlignment="center"
                                            android:text="0.00"
                                            android:id="@+id/txpamt"
                                            android:layout_weight="1"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"/>
                                    </LinearLayout>

                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </androidx.core.widget.NestedScrollView>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>