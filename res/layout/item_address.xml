<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:padding="5dp"
    android:layout_margin="3dp"
    android:id="@+id/linear_layout"
    android:background="@drawable/box_round"
    android:layout_height="wrap_content">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <TextView
                android:id="@+id/txnm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/custom_font"
                android:padding="3dp"
                android:text="XXXX"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txaddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/custom_font"
                android:padding="3dp"
                android:text="XXXX"
                android:textColor="@color/black"
                android:textSize="14dp" />

            <TextView
                android:id="@+id/txmob"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/custom_font"
                android:padding="3dp"
                android:text="XXXX"
                android:textColor="@color/black"
                android:textSize="14dp" />

            <TextView
                android:id="@+id/txmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/custom_font"
                android:padding="3dp"
                android:text="XXXX"
                android:textColor="@color/black"
                android:textSize="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="3dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btedit"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/button"
                    android:fontFamily="@font/custom_font"
                    android:text="EDIT"
                    android:textColor="@color/black"
                    android:textSize="13dp" />

                <!--        <Button-->
                <!--            android:layout_margin="2dp"-->
                <!--            android:fontFamily="@font/custom_font"-->
                <!--            android:textColor="@color/white"-->
                <!--            android:background="@drawable/btnorange"-->
                <!--            android:id="@+id/btdel"-->
                <!--            android:text="DELETE"-->
                <!--            android:textSize="13dp"-->
                <!--            android:layout_weight="1"-->
                <!--            android:layout_width="match_parent"-->
                <!--            android:layout_height="35dp"/>-->

                <Button
                    android:id="@+id/btdefault"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/button"
                    android:fontFamily="@font/custom_font"
                    android:text="MAKE DEFAULT"
                    android:textColor="@color/black"
                    android:textSize="13dp" />

            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/btdel"
            android:padding="5dp"
            android:src="@drawable/delete"
            android:layout_width="30dp"
            android:background="@drawable/round_yellow"
            android:layout_gravity="right|end"
            android:layout_height="30dp"/>
    </FrameLayout>
</LinearLayout>